# Database
DATABASE_URL=postgresql://hub_user:hub_password@postgres:5432/financial_hub
# Connection pool size (keep low to avoid exhausting Postgres connections)
DB_POOL_MAX=5
DB_POOL_IDLE_TIMEOUT=10000

# Source types: comma-separated list of value:label pairs
NEXT_PUBLIC_SOURCE_TYPES=wechat:微信公众号,youtube:YouTube,xiaoyuzhou:小宇宙播客,substack:Substack

# 爬虫下载根目录。调度器启动每个子爬虫时会在此目录后拼接 source_type，
# 作为该爬虫的下载目录（CRAWLER_OUTPUT_DIR=DOWNLOAD_ROOT/<source_type>）。
# 留空则各爬虫使用自身默认的 output 目录。
DOWNLOAD_ROOT=/data/financial_hub/downloads
